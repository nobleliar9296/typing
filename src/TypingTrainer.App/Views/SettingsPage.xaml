<Page
    x:Class="TypingTrainer.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="SettingsPage_Loaded">

    <Grid RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="32,24,32,0" Spacing="3">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
            <TextBlock
                Text="Local typing, content, visual keyboard, and data preferences"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="32,0,32,24">
            <StackPanel Spacing="18" MaxWidth="1040">
                <Border Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Preferences autosave locally" FontWeight="SemiBold" />
                            <TextBlock Text="Changes are written to the local SQLite settings store after a short pause." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding SettingsStatus}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Border>

                <Grid ColumnSpacing="18" RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="18" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Typing" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Lesson behavior and completion saving." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <Grid ColumnSpacing="14" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Default mode" VerticalAlignment="Center" />
                                <ComboBox
                                    x:Name="DefaultLessonModeComboBox"
                                    Grid.Column="1"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    SelectionChanged="DefaultLessonModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="Fixed" />
                                    <ComboBoxItem Content="Adaptive" />
                                    <ComboBoxItem Content="Paragraph" />
                                    <ComboBoxItem Content="Weak Keys" />
                                    <ComboBoxItem Content="Weak Bigrams" />
                                    <ComboBoxItem Content="Review" />
                                    <ComboBoxItem Content="Clipboard" />
                                </ComboBox>

                                <TextBlock Grid.Row="1" Text="Lesson length" VerticalAlignment="Center" />
                                <NumberBox
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="160"
                                    HorizontalAlignment="Left"
                                    Minimum="20"
                                    Maximum="5000"
                                    SmallChange="10"
                                    LargeChange="50"
                                    Value="{Binding LessonLengthCharacters, Mode=TwoWay}" />

                                <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Backspace allowed" IsChecked="{Binding BackspaceAllowed, Mode=TwoWay}" />
                                <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Auto-save completed sessions" IsChecked="{Binding AutoSaveCompletedSessions, Mode=TwoWay}" />
                                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Spacing="4">
                                    <CheckBox Content="Require correct key to advance" IsChecked="{Binding RequireCorrectKeyToAdvance, Mode=TwoWay}" />
                                    <TextBlock
                                        Text="Wrong keys count as mistakes, but the cursor stays put until the expected key is typed."
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Grid.Row="5" Text="Training focus" VerticalAlignment="Center" />
                                <ComboBox
                                    x:Name="TrainingFocusComboBox"
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    SelectionChanged="TrainingFocusComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Balanced" />
                                    <ComboBoxItem Content="Accuracy First" />
                                    <ComboBoxItem Content="Speed First" />
                                    <ComboBoxItem Content="Weak Left Hand" />
                                    <ComboBoxItem Content="Weak Right Hand" />
                                    <ComboBoxItem Content="Punctuation" />
                                </ComboBox>

                                <TextBlock Grid.Row="6" Text="Session minutes" VerticalAlignment="Center" />
                                <NumberBox
                                    Grid.Row="6"
                                    Grid.Column="1"
                                    Width="120"
                                    HorizontalAlignment="Left"
                                    Minimum="5"
                                    Maximum="60"
                                    Value="{Binding GoalTargetSessionMinutes, Mode=TwoWay}" />

                                <TextBlock Grid.Row="7" Text="Essay words" VerticalAlignment="Center" />
                                <NumberBox
                                    Grid.Row="7"
                                    Grid.Column="1"
                                    Width="120"
                                    HorizontalAlignment="Left"
                                    Minimum="100"
                                    Maximum="3000"
                                    Value="{Binding GoalTargetEssayWords, Mode=TwoWay}" />
                            </Grid>

                            <StackPanel Spacing="8">
                                <CheckBox Content="Zen Mode during practice" IsChecked="{Binding ZenModeEnabled, Mode=TwoWay}" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Countdown" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="3" StepFrequency="1" Value="{Binding CountdownSeconds, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="2" Text="{Binding CountdownText}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="18">
                                    <CheckBox Content="Key sounds" IsChecked="{Binding KeySoundEnabled, Mode=TwoWay}" />
                                    <CheckBox Content="Mistake sounds" IsChecked="{Binding MistakeSoundEnabled, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="18" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Practice Display" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Adjust the active practice surface." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Text size" VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="70" Maximum="130" StepFrequency="5" Value="{Binding PracticeTextScalePercent, Mode=TwoWay}" />
                                <NumberBox Grid.Column="2" Minimum="70" Maximum="130" SmallChange="5" LargeChange="10" Value="{Binding PracticeTextScalePercent, Mode=TwoWay}" />
                                <TextBlock Grid.Column="3" Text="{Binding PracticeTextScaleText}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <TextBlock Grid.Row="1" Text="Keyboard size" VerticalAlignment="Center" />
                                <Slider Grid.Row="1" Grid.Column="1" Minimum="70" Maximum="130" StepFrequency="5" Value="{Binding VisualKeyboardScalePercent, Mode=TwoWay}" />
                                <NumberBox Grid.Row="1" Grid.Column="2" Minimum="70" Maximum="130" SmallChange="5" LargeChange="10" Value="{Binding VisualKeyboardScalePercent, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding VisualKeyboardScaleText}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <CheckBox Grid.Row="2" Grid.ColumnSpan="4" Content="Show visual keyboard" IsChecked="{Binding ShowVisualKeyboard, Mode=TwoWay}" />
                                <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="18">
                                    <CheckBox Content="Show finger colors" IsChecked="{Binding ShowFingerColors, Mode=TwoWay}" />
                                    <CheckBox Content="Show finger labels" IsChecked="{Binding ShowFingerLabels, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Grid.Row="4" Text="Font" VerticalAlignment="Center" />
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding PracticeFontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="5" Text="Line width" VerticalAlignment="Center" />
                                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding PracticeLineWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6" Text="Contrast / cursor" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8">
                                    <TextBox Width="140" Text="{Binding PracticeTextContrast, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Width="140" Text="{Binding PracticeCursorStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Theme" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox
                                    x:Name="ThemePresetComboBox"
                                    Width="180"
                                    SelectionChanged="ThemePresetComboBox_SelectionChanged">
                                    <ComboBoxItem Content="System" />
                                    <ComboBoxItem Content="Dark" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Ink" />
                                    <ComboBoxItem Content="Forest" />
                                    <ComboBoxItem Content="Dawn" />
                                    <ComboBoxItem Content="High Contrast" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="18" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Content" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Only import text you wrote, own, or have permission to use." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="TXT file path" Text="{Binding ImportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="BrowseImportButton_Click" />
                            </Grid>

                            <TextBox Header="Pack name" Text="{Binding ImportPackName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Import .txt file" Click="ImportButton_Click" />
                                <Button Content="Cancel Import" Click="CancelImportButton_Click" />
                                <Button Content="Refresh Packs" Click="RefreshPacksButton_Click" />
                            </StackPanel>

                            <ProgressBar IsIndeterminate="True" Visibility="{Binding ImportProgressVisibility}" />
                            <TextBlock Text="{Binding ImportStatus}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Difficulty" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ComboBox
                                        x:Name="DifficultyPresetComboBox"
                                        Width="180"
                                        SelectionChanged="DifficultyPresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Custom" />
                                        <ComboBoxItem Content="Speed Words" />
                                        <ComboBoxItem Content="Clean Copy" />
                                        <ComboBoxItem Content="Symbols" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <CheckBox Content="Use imported content" IsChecked="{Binding UseImportedContent, Mode=TwoWay}" />
                                    <CheckBox Content="Use built-in content" IsChecked="{Binding UseBuiltInContent, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <CheckBox Content="Allow capitals" IsChecked="{Binding AllowCapitalLetters, Mode=TwoWay}" />
                                    <CheckBox Content="Allow numbers" IsChecked="{Binding AllowNumbers, Mode=TwoWay}" />
                                    <CheckBox Content="Allow punctuation" IsChecked="{Binding AllowPunctuation, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Import cleanup" FontWeight="SemiBold" />
                                <CheckBox Content="Normalize imported text to ASCII" IsChecked="{Binding NormalizeImportedTextToAscii, Mode=TwoWay}" />
                                <CheckBox Content="Normalize whitespace" IsChecked="{Binding NormalizeImportedWhitespace, Mode=TwoWay}" />
                                <CheckBox Content="Lowercase imported text" IsChecked="{Binding LowercaseImportedText, Mode=TwoWay}" />
                                <TextBlock
                                    Text="ASCII normalization fixes curly quotes, accents, dashes, and other characters that can be awkward to type."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Text="When Allow punctuation is off, new imports remove punctuation so paragraph mode can still use the text."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <Border
                                Padding="12"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Import preview" FontWeight="SemiBold" />
                                            <TextBlock
                                                Text="{Binding ImportPreviewStatus}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ItemsControl
                                            Grid.Column="1"
                                            ItemsSource="{Binding ImportPreviewNotes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Padding="7,4"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <TextBlock
                                                            Text="{Binding}"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Header="Original sample"
                                            Text="{Binding ImportOriginalPreviewText, Mode=OneWay}"
                                            IsReadOnly="True"
                                            AcceptsReturn="True"
                                            TextWrapping="Wrap"
                                            MaxHeight="132" />
                                        <TextBox
                                            Grid.Column="1"
                                            Header="Typing sample"
                                            Text="{Binding ImportCleanedPreviewText, Mode=OneWay}"
                                            IsReadOnly="True"
                                            AcceptsReturn="True"
                                            TextWrapping="Wrap"
                                            MaxHeight="132" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="Selected pack name" Text="{Binding SelectedContentPackName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Grid.Column="1" Content="Enabled" VerticalAlignment="Bottom" IsChecked="{Binding SelectedContentPackEnabled, Mode=TwoWay}" />
                                <Button Grid.Column="2" Content="Save Pack" VerticalAlignment="Bottom" Click="SavePackButton_Click" />
                                <Button Grid.Row="1" Content="Preview Selected Pack" HorizontalAlignment="Left" Click="PreviewPackButton_Click" />
                            </Grid>

                            <ListView x:Name="ContentPacksListView" ItemsSource="{Binding ContentPackRows}" SelectionMode="Single" SelectionChanged="ContentPacksListView_SelectionChanged" MaxHeight="260">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12" Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding SourceFileName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{Binding ParagraphCount}" />
                                            <TextBlock Grid.Column="3" Text="{Binding FileSize}" />
                                            <TextBlock Grid.Column="4" Text="{Binding CreatedAt}" />
                                            <TextBlock Grid.Column="5" Text="{Binding Enabled}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <ListView ItemsSource="{Binding ContentPreviewRows}" SelectionMode="None" MaxHeight="180">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="0,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxLines="3" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Content="Delete Selected Content Pack" HorizontalAlignment="Left" Click="DeletePackButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Padding="18" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Data" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Export or clear local practice history." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <TextBox Header="Export path" Text="{Binding ExportPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Export Sessions JSON" Click="ExportSessionsButton_Click" />
                                <Button Content="Delete Practice History" Click="DeleteHistoryButton_Click" />
                            </StackPanel>
                            <TextBox Header="Database backup / restore path" Text="{Binding BackupPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Backup Database" Click="BackupDatabaseButton_Click" />
                                <Button Content="Restore Database" Click="RestoreDatabaseButton_Click" />
                            </StackPanel>
                            <TextBox Header="Keyboard layout" Width="180" HorizontalAlignment="Left" IsReadOnly="True" IsEnabled="False" Text="{Binding VisualKeyboardLayout}" />
                            <Border Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="About" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AppVersionText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="Local-first typing trainer. Practice history and imported content stay on this device." Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
