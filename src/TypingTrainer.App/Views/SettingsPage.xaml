<Page
    x:Class="TypingTrainer.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="SettingsPage_Loaded">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="10">
            <TextBlock Text="TypingTrainer" FontSize="28" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Practice" Click="PracticeButton_Click" />
                <Button Content="Dashboard" Click="DashboardButton_Click" />
                <Button Content="Settings" IsEnabled="False" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24" MaxWidth="980">
                <TextBlock Text="{Binding SettingsStatus}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel Spacing="12">
                    <TextBlock Text="Typing" FontSize="22" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Default lesson mode" VerticalAlignment="Center" />
                        <ComboBox
                            x:Name="DefaultLessonModeComboBox"
                            Grid.Column="1"
                            Width="220"
                            SelectionChanged="DefaultLessonModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Auto" />
                            <ComboBoxItem Content="Fixed" />
                            <ComboBoxItem Content="Adaptive" />
                            <ComboBoxItem Content="Paragraph" />
                            <ComboBoxItem Content="Weak Keys" />
                            <ComboBoxItem Content="Weak Bigrams" />
                            <ComboBoxItem Content="Review" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" Text="Lesson length" VerticalAlignment="Center" />
                        <NumberBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Width="160"
                            Minimum="20"
                            Maximum="5000"
                            SmallChange="10"
                            LargeChange="50"
                            Value="{Binding LessonLengthCharacters, Mode=TwoWay}" />

                        <CheckBox
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Content="Backspace allowed"
                            IsChecked="{Binding BackspaceAllowed, Mode=TwoWay}" />
                        <CheckBox
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Content="Auto-save completed sessions"
                            IsChecked="{Binding AutoSaveCompletedSessions, Mode=TwoWay}" />
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Spacing="4">
                            <CheckBox
                                Content="Require correct key to advance"
                                IsChecked="{Binding RequireCorrectKeyToAdvance, Mode=TwoWay}" />
                            <TextBlock
                                Text="When enabled, wrong keys are counted as mistakes but the cursor stays on the same character until you type it correctly. This change applies to the next lesson."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Visual Keyboard" FontSize="22" FontWeight="SemiBold" />
                    <CheckBox
                        Content="Show visual keyboard"
                        IsChecked="{Binding ShowVisualKeyboard, Mode=TwoWay}" />
                    <CheckBox
                        Content="Show finger colors"
                        IsChecked="{Binding ShowFingerColors, Mode=TwoWay}" />
                    <CheckBox
                        Content="Show finger labels"
                        IsChecked="{Binding ShowFingerLabels, Mode=TwoWay}" />
                    <TextBox
                        Header="Keyboard layout"
                        Width="180"
                        HorizontalAlignment="Left"
                        IsReadOnly="True"
                        IsEnabled="False"
                        Text="{Binding VisualKeyboardLayout}" />
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Content" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock
                        Text="Only import text you wrote, own, or have permission to use."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Header="TXT file path"
                            Text="{Binding ImportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Grid.Column="1"
                            Content="Browse"
                            VerticalAlignment="Bottom"
                            Click="BrowseImportButton_Click" />
                    </Grid>

                    <TextBox
                        Header="Pack name"
                        Text="{Binding ImportPackName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import .txt file" Click="ImportButton_Click" />
                        <Button Content="Cancel Import" Click="CancelImportButton_Click" />
                        <Button Content="Refresh Packs" Click="RefreshPacksButton_Click" />
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True" Visibility="{Binding ImportProgressVisibility}" />
                    <TextBlock Text="{Binding ImportStatus}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Use imported content" IsChecked="{Binding UseImportedContent, Mode=TwoWay}" />
                        <CheckBox Content="Use built-in content" IsChecked="{Binding UseBuiltInContent, Mode=TwoWay}" />
                        <CheckBox Content="Allow capitals" IsChecked="{Binding AllowCapitalLetters, Mode=TwoWay}" />
                        <CheckBox Content="Allow numbers" IsChecked="{Binding AllowNumbers, Mode=TwoWay}" />
                        <CheckBox Content="Allow punctuation" IsChecked="{Binding AllowPunctuation, Mode=TwoWay}" />
                    </StackPanel>

                    <ListView
                        x:Name="ContentPacksListView"
                        ItemsSource="{Binding ContentPackRows}"
                        SelectionMode="Single"
                        SelectionChanged="ContentPacksListView_SelectionChanged"
                        MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" Text="{Binding SourceFileName}" />
                                    <TextBlock Grid.Column="2" Text="{Binding ParagraphCount}" />
                                    <TextBlock Grid.Column="3" Text="{Binding CreatedAt}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Content="Delete Selected Content Pack" Click="DeletePackButton_Click" />
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Data" FontSize="22" FontWeight="SemiBold" />
                    <TextBox Header="Export path" Text="{Binding ExportPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Sessions JSON" Click="ExportSessionsButton_Click" />
                        <Button Content="Delete Practice History" Click="DeleteHistoryButton_Click" />
                        <Button Content="Save Settings" Click="SaveSettingsButton_Click" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
