<Page
    x:Class="TypingTrainer.App.Views.SessionDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    SizeChanged="SessionDetailPage_SizeChanged">

    <Grid x:Name="SessionDetailRootGrid" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="SessionDetailScrollViewer" Grid.Row="0" Margin="32,24,32,24">
            <StackPanel x:Name="SessionDetailContentPanel" Spacing="22">
                <StackPanel x:Name="SessionDetailHeaderPanel" Spacing="4">
                    <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Local session drill-down" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <ProgressRing Width="32" Height="32" HorizontalAlignment="Left" IsActive="{Binding IsLoading}" Visibility="{Binding LoadingVisibility}" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="{Binding ErrorVisibility}" />

                <Grid x:Name="SessionSummaryGrid" ColumnSpacing="12" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="NetWpmSummaryCard" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding NetWpmText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="AccuracySummaryCard" Grid.Column="1" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding AccuracyText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="DurationSummaryCard" Grid.Column="2" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding DurationText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Duration" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="MistakesSummaryCard" Grid.Column="3" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding MistakesText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Mistakes" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="QualitySummaryCard" Grid.Column="4" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding QualityScoreText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding QualityGradeText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Consistency" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding QualityExplanationText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="Dips can point to fatigue, pauses, or mistake clusters during the session." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid x:Name="ConsistencyChartsGrid" ColumnSpacing="18" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="SessionNetWpmChartCard" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Net WPM over session" FontWeight="SemiBold" />
                                <controls:TrendLineChart Points="{Binding TimelineNetWpmPoints}" ValueSuffix=" WPM" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="SessionAccuracyChartCard" Grid.Column="1" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Accuracy over session" FontWeight="SemiBold" />
                                <controls:TrendLineChart Points="{Binding TimelineAccuracyPoints}" ValueSuffix="%" MaximumValue="100" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Grid x:Name="TimelineMistakesGrid" ColumnSpacing="18" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Timeline Samples" FontSize="20" FontWeight="SemiBold" />
                        <ListView
                            x:Name="TimelineListView"
                            ItemsSource="{Binding TimelineRows}"
                            SelectionMode="None"
                            MaxHeight="260"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollMode="Enabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1" Text="{Binding NetWpm}" />
                                        <TextBlock Grid.Column="2" Text="{Binding AccuracyPercent}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="Mistakes" FontSize="20" FontWeight="SemiBold" />
                        <ListView
                            x:Name="MistakesListView"
                            ItemsSource="{Binding MistakeRows}"
                            SelectionMode="None"
                            MaxHeight="260"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollMode="Enabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10" Padding="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Position}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Expected}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Actual}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Kind}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>

                <Grid x:Name="SlowestListsGrid" ColumnSpacing="18" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Slowest Keys" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding SlowestKeyRows}" SelectionMode="None" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="Slowest Bigrams" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding SlowestBigramRows}" SelectionMode="None" />
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="SessionDetailActionsPanel" Orientation="Horizontal" Spacing="8">
                    <Button Content="Back to Dashboard" Click="BackButton_Click" />
                    <Button Content="Replay Mistakes" Click="ReplayMistakesButton_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
