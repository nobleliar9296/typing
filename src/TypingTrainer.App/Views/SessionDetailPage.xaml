<Page
    x:Class="TypingTrainer.App.Views.SessionDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:AppTopBar ActivePage="Dashboard" />

        <ScrollViewer Grid.Row="1" Margin="32,24,32,24">
            <StackPanel Spacing="22">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Local session drill-down" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <ProgressRing Width="32" Height="32" HorizontalAlignment="Left" IsActive="{Binding IsLoading}" Visibility="{Binding LoadingVisibility}" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="{Binding ErrorVisibility}" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding NetWpmText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding AccuracyText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding DurationText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Duration" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="14" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding MistakesText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Mistakes" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Timeline" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding TimelineRows}" SelectionMode="None" MaxHeight="260">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1" Text="{Binding NetWpm}" />
                                        <TextBlock Grid.Column="2" Text="{Binding AccuracyPercent}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="Mistakes" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding MistakeRows}" SelectionMode="None" MaxHeight="260">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10" Padding="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Position}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Expected}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Actual}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Kind}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Slowest Keys" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding SlowestKeyRows}" SelectionMode="None" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="Slowest Bigrams" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding SlowestBigramRows}" SelectionMode="None" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Back to Dashboard" Click="BackButton_Click" />
                    <Button Content="Replay Mistakes" Click="ReplayMistakesButton_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

