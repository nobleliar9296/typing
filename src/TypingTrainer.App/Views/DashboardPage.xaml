<Page
    x:Class="TypingTrainer.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="DashboardPage_Loaded">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="10">
                <TextBlock
                    Text="TypingTrainer"
                    FontSize="28"
                    FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Practice" Click="PracticeButton_Click" />
                    <Button Content="Dashboard" IsEnabled="False" />
                    <Button Content="Settings" Click="SettingsButton_Click" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                <TextBlock
                    Text="Analytics"
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox
                    x:Name="RangeComboBox"
                    Width="180"
                    SelectedIndex="0"
                    SelectionChanged="RangeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Last 7 days" />
                    <ComboBoxItem Content="Last 30 days" />
                    <ComboBoxItem Content="All time" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24">
                <ProgressRing
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Left"
                    IsActive="{Binding IsLoading}"
                    Visibility="{Binding LoadingVisibility}" />

                <TextBlock
                    Text="{Binding ErrorMessage}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="{Binding ErrorVisibility}" />

                <TextBlock
                    Text="No analytics yet. Complete a practice session to see your WPM, accuracy, weak keys, and typing trends."
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Visibility="{Binding EmptyStateVisibility}" />

                <StackPanel Spacing="24" Visibility="{Binding DashboardContentVisibility}">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding SessionCountText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Sessions" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding PracticeTimeText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Practice Time" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding AverageNetWpmText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Avg Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding BestNetWpmText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Best Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding AccuracyText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="2" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorsText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Errors" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="16" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Net WPM" FontSize="20" FontWeight="SemiBold" />
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:TrendLineChart Points="{Binding NetWpmPoints}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Accuracy" FontSize="20" FontWeight="SemiBold" />
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:TrendLineChart Points="{Binding AccuracyPoints}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                            <TextBlock Text="Practice Time" FontSize="20" FontWeight="SemiBold" />
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:BarChart Points="{Binding PracticeTimePoints}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Daily Trend" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding DailyMetricRows}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Date}" />
                                        <TextBlock Grid.Column="1" Text="{Binding AverageNetWpm}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Accuracy}" />
                                        <TextBlock Grid.Column="3" Text="{Binding PracticeTime}" />
                                        <TextBlock Grid.Column="4" Text="{Binding SessionCount}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Weakest Keys" FontSize="20" FontWeight="SemiBold" />
                            <ListView ItemsSource="{Binding WeakestCharacterRows}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Accuracy}" />
                                            <TextBlock Grid.Column="2" Text="{Binding MedianLatencyMs}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ExposureCount}" />
                                            <ProgressBar Grid.Column="4" Maximum="100" Value="{Binding WeaknessPercent}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Slowest Keys" FontSize="20" FontWeight="SemiBold" />
                            <ListView ItemsSource="{Binding SlowestCharacterRows}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Accuracy}" />
                                            <TextBlock Grid.Column="2" Text="{Binding MedianLatencyMs}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ExposureCount}" />
                                            <ProgressBar Grid.Column="4" Maximum="100" Value="{Binding WeaknessPercent}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Weakest Bigrams" FontSize="20" FontWeight="SemiBold" />
                            <ListView ItemsSource="{Binding WeakestBigramRows}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Accuracy}" />
                                            <TextBlock Grid.Column="2" Text="{Binding MedianLatencyMs}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ExposureCount}" />
                                            <ProgressBar Grid.Column="4" Maximum="100" Value="{Binding WeaknessPercent}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Slowest Bigrams" FontSize="20" FontWeight="SemiBold" />
                            <ListView ItemsSource="{Binding SlowestBigramRows}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Accuracy}" />
                                            <TextBlock Grid.Column="2" Text="{Binding MedianLatencyMs}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ExposureCount}" />
                                            <ProgressBar Grid.Column="4" Maximum="100" Value="{Binding WeaknessPercent}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Recent Sessions" FontSize="20" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding RecentSessionRows}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StartedAt}" />
                                        <TextBlock Grid.Column="1" Text="{Binding NetWpm}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Accuracy}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Duration}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Mode}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
