<Page
    x:Class="TypingTrainer.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="DashboardPage_Loaded"
    SizeChanged="DashboardPage_SizeChanged">

    <Grid x:Name="DashboardRootGrid" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="DashboardHeaderGrid" Grid.Row="0" Margin="32,24,32,0" ColumnSpacing="24" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DashboardHeaderTitleColumn" Width="*" />
                <ColumnDefinition x:Name="DashboardHeaderModeColumn" Width="Auto" />
                <ColumnDefinition x:Name="DashboardHeaderRangeColumn" Width="Auto" />
                <ColumnDefinition x:Name="DashboardHeaderKeysColumn" Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="DashboardTitlePanel" Spacing="3">
                <TextBlock
                    Text="Analytics"
                    FontSize="28"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="Local typing performance, trends, and practice goals"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="ModeFilterPanel" Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                <TextBlock
                    Text="Mode"
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox
                    x:Name="ModeFilterComboBox"
                    Width="180"
                    SelectedIndex="0"
                    SelectionChanged="ModeFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="All modes" />
                    <ComboBoxItem Content="Adaptive" />
                    <ComboBoxItem Content="Paragraph" />
                    <ComboBoxItem Content="Weak Keys" />
                    <ComboBoxItem Content="Weak Bigrams" />
                    <ComboBoxItem Content="Review" />
                    <ComboBoxItem Content="Clipboard" />
                    <ComboBoxItem Content="Fixed" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="RangeFilterPanel" Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                <TextBlock
                    Text="Range"
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox
                    x:Name="RangeComboBox"
                    Width="180"
                    SelectedIndex="0"
                    SelectionChanged="RangeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Last 7 days" />
                    <ComboBoxItem Content="Last 30 days" />
                    <ComboBoxItem Content="All time" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="KeyFilterPanel" Grid.Column="3" Spacing="8" VerticalAlignment="Center">
                <TextBlock
                    Text="Keys"
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox
                    x:Name="KeyFilterComboBox"
                    Width="160"
                    SelectedIndex="0"
                    SelectionChanged="KeyFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="All keys" />
                    <ComboBoxItem Content="Left hand" />
                    <ComboBoxItem Content="Right hand" />
                    <ComboBoxItem Content="Home row" />
                    <ComboBoxItem Content="Top row" />
                    <ComboBoxItem Content="Bottom row" />
                    <ComboBoxItem Content="Letters" />
                    <ComboBoxItem Content="Punctuation" />
                    <ComboBoxItem Content="Numbers" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer x:Name="DashboardScrollViewer" Grid.Row="1" Margin="32,0,32,24">
            <StackPanel x:Name="DashboardContentPanel" Spacing="24">
                <ProgressRing
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Left"
                    IsActive="{Binding IsLoading}"
                    Visibility="{Binding LoadingVisibility}" />

                <TextBlock
                    Text="{Binding ErrorMessage}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="{Binding ErrorVisibility}" />

                <TextBlock
                    Text="No analytics yet. Complete a practice session to see your WPM, accuracy, weak keys, and typing trends."
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Visibility="{Binding EmptyStateVisibility}" />

                <Border
                    x:Name="GoalPanelCard"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Visibility="{Binding GoalPanelVisibility}">
                    <StackPanel Spacing="14">
                        <Grid x:Name="GoalHeaderGrid" ColumnSpacing="16" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Typing Goal" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="Set a local target and use the plan below to decide what to practice next."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding GoalStatus}"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <Grid x:Name="GoalMetricsGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding GoalCurrentNetWpmText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Current avg net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding GoalTargetNetWpmText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Target net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding GoalWpmGapText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Speed gap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="{Binding GoalTargetAccuracyText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Target accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="{Binding GoalWeeklyPracticeText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Practice target" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="{Binding GoalWeeklyProgressText}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Weekly progress" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="GoalInputsGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="GoalTargetWpmNumberBox"
                                Header="Target net WPM"
                                Minimum="10"
                                Maximum="250"
                                SmallChange="1"
                                LargeChange="5"
                                Value="{Binding GoalTargetNetWpm, Mode=TwoWay}" />
                            <NumberBox
                                x:Name="GoalTargetAccuracyNumberBox"
                                Grid.Column="1"
                                Header="Target accuracy %"
                                Minimum="50"
                                Maximum="100"
                                SmallChange="1"
                                LargeChange="5"
                                Value="{Binding GoalTargetAccuracyPercent, Mode=TwoWay}" />
                            <NumberBox
                                x:Name="GoalWeeklyMinutesNumberBox"
                                Grid.Column="2"
                                Header="Weekly minutes"
                                Minimum="0"
                                Maximum="10080"
                                SmallChange="5"
                                LargeChange="30"
                                Value="{Binding GoalWeeklyPracticeMinutes, Mode=TwoWay}" />
                            <Button
                                x:Name="SaveGoalsButton"
                                Grid.Column="3"
                                Content="Save Goals"
                                VerticalAlignment="Bottom"
                                Click="SaveGoalsButton_Click" />
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Path to your goal" FontWeight="SemiBold" />
                            <Border
                                Padding="12"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                CornerRadius="6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="Today&apos;s recommendation" FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding TodayRecommendationText}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding GoalActionSteps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Margin="0,2,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ItemsControl
                    x:Name="InsightRowsItemsControl"
                    ItemsSource="{Binding InsightRows}"
                    Visibility="{Binding GoalPanelVisibility}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="260"
                                MinHeight="118"
                                Margin="0,0,12,0"
                                Padding="14"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="5">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{Binding Value}"
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{Binding Detail}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"
                                        MaxLines="2" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid x:Name="DailyCoachGrid" ColumnSpacing="16" RowSpacing="16" Visibility="{Binding GoalPanelVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="DailyCoachCard" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Daily Coach" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DailyPlan.Summary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ListView
                                x:Name="DailyPlanListView"
                                ItemsSource="{Binding DailyPlanRows}"
                                SelectionMode="None"
                                MaxHeight="220"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollMode="Enabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="70" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Order}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{Binding Mode}" />
                                            <TextBlock Grid.Column="4" Text="{Binding Minutes}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Content="Start Daily Plan" HorizontalAlignment="Left" Click="StartDailyPlanButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="AchievementsCard" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Achievements" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Computed locally from saved practice history." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ListView x:Name="AchievementsListView" ItemsSource="{Binding AchievementRows}" SelectionMode="None" MaxHeight="220">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Spacing="24" Visibility="{Binding DashboardContentVisibility}">
                    <Grid x:Name="SummaryMetricsGrid" ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SessionsSummaryCard" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding SessionCountText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Sessions" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="PracticeTimeSummaryCard" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding PracticeTimeText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Practice Time" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="AverageWpmSummaryCard" Grid.Column="2" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding AverageNetWpmText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Avg Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="BestWpmSummaryCard" Grid.Row="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding BestNetWpmText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Best Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="AccuracySummaryCard" Grid.Row="1" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding AccuracyText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="ErrorsSummaryCard" Grid.Row="1" Grid.Column="2" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorsText}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Errors" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="QualityBestGrid" ColumnSpacing="16" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TrainingQualityCard" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Training Quality" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="A balanced score from accuracy, speed, consistency, and control." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding QualityAverageText}" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock Text="Avg quality" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding QualityBestText}" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock Text="Best score" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding QualityGradeText}" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock Text="Current grade" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding QualityTrendText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Border Padding="10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                    <controls:TrendLineChart Points="{Binding QualityTrendPoints}" ValueSuffix="" MaximumValue="100" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border x:Name="PersonalBestsCard" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Personal Bests" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Records recomputed from local saved history." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <ListView
                                    x:Name="PersonalBestListView"
                                    ItemsSource="{Binding PersonalBestRows}"
                                    SelectionMode="None"
                                    IsItemClickEnabled="True"
                                    ItemClick="PersonalBestListView_ItemClick"
                                    MaxHeight="330"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollMode="Enabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="12" Padding="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Detail}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Practice Calendar" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Local practice days for the selected range. Bars show progress toward a daily share of your weekly goal." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding PracticeCalendarRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="122"
                                        MinHeight="92"
                                        Margin="0,0,8,8"
                                        Padding="10"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        ToolTipService.ToolTip="{Binding ToolTip}">
                                        <StackPanel Spacing="6">
                                            <Grid>
                                                <TextBlock Text="{Binding Date}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Sessions}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <ProgressBar Maximum="100" Value="{Binding PracticePercent}" />
                                            <Grid>
                                                <TextBlock Text="{Binding PracticeTime}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding Quality}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid x:Name="TrendChartsGrid" ColumnSpacing="16" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="NetWpmChartPanel" Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Net WPM" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Daily average net words per minute" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:TrendLineChart Points="{Binding NetWpmPoints}" ValueSuffix=" WPM" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="AccuracyChartPanel" Grid.Column="1" Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Accuracy" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Daily keypress accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:TrendLineChart Points="{Binding AccuracyPoints}" ValueSuffix="%" MaximumValue="100" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="PracticeTimeChartPanel" Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Practice Time" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Daily minutes practiced" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Border Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="8">
                                <controls:BarChart Points="{Binding PracticeTimePoints}" ValueSuffix=" min" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Daily Trend" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock
                                Text="Grouped by your local calendar date."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ListView
                            x:Name="DailyMetricListView"
                            ItemsSource="{Binding DailyMetricRows}"
                            SelectionMode="None"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollMode="Enabled">
                            <ListView.Header>
                                <Grid ColumnSpacing="12" Padding="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Date" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="2" Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
