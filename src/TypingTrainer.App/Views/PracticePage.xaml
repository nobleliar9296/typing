<Page
    x:Class="TypingTrainer.App.Views.PracticePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="PracticePage_Loaded">

    <Grid
        x:Name="PracticeRoot"
        RowSpacing="24"
        SizeChanged="PracticeRoot_SizeChanged"
        PointerPressed="PracticeRoot_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:AppTopBar ActivePage="Practice" />

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="1"
            Margin="32,24,32,0"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="HeaderTopGrid"
                ColumnSpacing="16"
                RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderTitleColumn" Width="Auto" />
                    <ColumnDefinition x:Name="HeaderSpacerColumn" Width="*" />
                    <ColumnDefinition x:Name="HeaderControlsColumn" Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="TitlePanel"
                    Spacing="2">
                    <TextBlock
                        x:Name="TitleText"
                        Text="TypingTrainer"
                        FontSize="28"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="LessonTitleText"
                        Text="{Binding LessonTitle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    x:Name="LessonSelectorsPanel"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Mode" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="LessonModeComboBox"
                            Width="160"
                            SelectedIndex="0"
                            SelectionChanged="LessonModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Adaptive" />
                            <ComboBoxItem Content="Paragraph" />
                            <ComboBoxItem Content="Weak Keys" />
                            <ComboBoxItem Content="Weak Bigrams" />
                            <ComboBoxItem Content="Review" />
                            <ComboBoxItem Content="Fixed" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Size" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="LessonSizeComboBox"
                            Width="132"
                            SelectedIndex="0"
                            SelectionChanged="LessonSizeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Small" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Long" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid
                x:Name="HeaderContextGrid"
                Grid.Row="1"
                ColumnSpacing="14"
                RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ContextColumn0" Width="1.1*" />
                    <ColumnDefinition x:Name="ContextColumn1" Width="1*" />
                    <ColumnDefinition x:Name="ContextColumn2" Width="1*" />
                    <ColumnDefinition x:Name="ContextColumn3" Width="1.4*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="LessonReasonText"
                    Text="{Binding LessonReason}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="FocusKeysText"
                    Grid.Column="1"
                    Text="{Binding FocusKeysText}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    x:Name="FocusBigramsText"
                    Grid.Column="2"
                    Text="{Binding FocusBigramsText}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    x:Name="LessonContentText"
                    Grid.Column="3"
                    Text="{Binding LessonContentText}"
                    Visibility="{Binding LessonContentVisibility}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </Grid>

            <Grid
                x:Name="StatsGrid"
                Grid.Row="2"
                ColumnSpacing="8"
                RowSpacing="8"
                HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="KpiRow0" Height="Auto" />
                    <RowDefinition x:Name="KpiRow1" Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="KpiColumn0" Width="*" />
                    <ColumnDefinition x:Name="KpiColumn1" Width="*" />
                    <ColumnDefinition x:Name="KpiColumn2" Width="*" />
                    <ColumnDefinition x:Name="KpiColumn3" Width="*" />
                    <ColumnDefinition x:Name="KpiColumn4" Width="*" />
                    <ColumnDefinition x:Name="KpiColumn5" Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="RawWpmTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="RawWpmLabelText" Text="Raw WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="RawWpmValueText" Text="{Binding RawWpmText}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border x:Name="NetWpmTile" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="NetWpmLabelText" Text="Net WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="NetWpmValueText" Text="{Binding NetWpmText}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border x:Name="AccuracyTile" Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="AccuracyLabelText" Text="Accuracy" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="AccuracyValueText" Text="{Binding AccuracyText}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border x:Name="ElapsedTile" Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="ElapsedLabelText" Text="Time" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ElapsedValueText" Text="{Binding ElapsedText}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border x:Name="ErrorsTile" Grid.Column="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="ErrorsLabelText" Text="Errors" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ErrorsValueText" Text="{Binding ErrorsText}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border x:Name="ProgressTile" Grid.Column="5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="ProgressLabelText" Text="Progress" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ProgressValueText" Text="{Binding ProgressText}" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="CharactersText" Text="{Binding CharactersText}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel
            x:Name="PracticeContentPanel"
            Grid.Row="2"
            Margin="32,0,32,0"
            Spacing="18"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
            <controls:TypingInputSurface
                x:Name="InputSurface"
                CharacterReceived="InputSurface_CharacterReceived"
                KeyDown="InputSurface_KeyDown"
                PointerPressed="InputSurface_PointerPressed"
                Tapped="InputSurface_Tapped">
                <Border
                    x:Name="InputBorder"
                    MaxWidth="1100"
                    Padding="32"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="InputSurface_PointerPressed"
                    Tapped="InputSurface_Tapped">
                    <StackPanel Spacing="18">
                        <ScrollViewer
                            x:Name="PracticeTextScrollViewer"
                            MinHeight="190"
                            MaxHeight="360"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            PointerPressed="InputSurface_PointerPressed"
                            Tapped="InputSurface_Tapped">
                            <controls:PracticeTextPresenter
                                x:Name="PracticeTextPresenter"
                                State="{Binding CurrentState}" />
                        </ScrollViewer>
                        <TextBlock
                            Text="{Binding TypingFeedback}"
                            Visibility="{Binding TypingFeedbackVisibility}"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        <TextBlock
                            Text="{Binding PauseStatus}"
                            Visibility="{Binding PauseOverlayVisibility}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock
                            Text="{Binding CompletionStatus}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel
                            Spacing="14"
                            Visibility="{Binding CompletionPanelVisibility}">
                            <TextBlock Text="Session complete" FontSize="22" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionRawWpmText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Raw WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionNetWpmText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="88">
                                    <TextBlock Text="{Binding CompletionAccuracyText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionErrorsText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Errors" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Restart" Click="RestartButton_Click" />
                                <Button Content="Next Lesson" Click="NextLessonButton_Click" />
                                <Button Content="View Dashboard" Click="ViewDashboardButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </controls:TypingInputSurface>
            <controls:VisualKeyboardControl
                x:Name="VisualKeyboard"
                Layout="{Binding VisualKeyboardLayout}"
                HighlightedKeyId="{Binding HighlightedKeyId}"
                HighlightedShiftKeyId="{Binding HighlightedShiftKeyId}"
                ShowFingerColors="{Binding ShowFingerColors}"
                ShowFingerLabels="{Binding ShowFingerLabels}"
                Visibility="{Binding VisualKeyboardVisibility}" />
        </StackPanel>
    </Grid>
</Page>
