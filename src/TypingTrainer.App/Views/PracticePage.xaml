<Page
    x:Class="TypingTrainer.App.Views.PracticePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="PracticePage_Loaded">

    <Grid
        x:Name="PracticeRoot"
        RowSpacing="24"
        SizeChanged="PracticeRoot_SizeChanged"
        PointerPressed="PracticeRoot_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            Margin="32,24,32,0"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="HeaderTopGrid"
                ColumnSpacing="16"
                RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderTitleColumn" Width="Auto" />
                    <ColumnDefinition x:Name="HeaderSpacerColumn" Width="*" />
                    <ColumnDefinition x:Name="HeaderControlsColumn" Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="LessonSelectorsPanel"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Mode" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="LessonModeComboBox"
                            Width="160"
                            SelectedIndex="0"
                            SelectionChanged="LessonModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Adaptive" />
                            <ComboBoxItem Content="Paragraph" />
                            <ComboBoxItem Content="Weak Keys" />
                            <ComboBoxItem Content="Weak Bigrams" />
                            <ComboBoxItem Content="Review" />
                            <ComboBoxItem Content="Copied Text" />
                            <ComboBoxItem Content="Fixed" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Size" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="LessonSizeComboBox"
                            Width="132"
                            SelectedIndex="0"
                            SelectionChanged="LessonSizeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Small" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Long" />
                        </ComboBox>
                    </StackPanel>
                    <ToggleSwitch
                        MinWidth="88"
                        OffContent="Zen"
                        OnContent="Zen"
                        IsOn="{Binding ZenModeEnabled, Mode=TwoWay}" />
                    <Button Content="Practice copied text" Click="ClipboardLessonButton_Click" />
                </StackPanel>
            </Grid>

            <Grid
                x:Name="HeaderContextGrid"
                Grid.Row="1"
                ColumnSpacing="14"
                RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ContextColumn0" Width="1.1*" />
                    <ColumnDefinition x:Name="ContextColumn1" Width="1*" />
                    <ColumnDefinition x:Name="ContextColumn2" Width="1*" />
                    <ColumnDefinition x:Name="ContextColumn3" Width="1.4*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="LessonReasonText"
                    Text="{Binding LessonReason}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="FocusKeysText"
                    Grid.Column="1"
                    Text="{Binding FocusKeysText}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    x:Name="FocusBigramsText"
                    Grid.Column="2"
                    Text="{Binding FocusBigramsText}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    x:Name="LessonContentText"
                    Grid.Column="3"
                    Text="{Binding LessonContentText}"
                    Visibility="{Binding LessonContentVisibility}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </Grid>
            <TextBlock
                Grid.Row="2"
                Text="{Binding ClipboardStatus}"
                Visibility="{Binding ClipboardStatusVisibility}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

        </Grid>

        <Grid
            x:Name="PracticeContentHost"
            Grid.Row="1"
            Opacity="{Binding PracticeContentOpacity}">
        <StackPanel
            x:Name="PracticeContentPanel"
            Margin="32,0,32,0"
            Spacing="18"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
            <Grid
                x:Name="PracticeTypingGrid"
                ColumnSpacing="12"
                HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftStatsColumn" Width="132" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="RightStatsColumn" Width="132" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="LeftStatsPanel"
                    Spacing="8"
                    Visibility="{Binding PracticeStatsVisibility}"
                    VerticalAlignment="Top">
                    <Border x:Name="RawWpmTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RawWpmLabelText" Text="Raw WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="RawWpmValueText" Text="{Binding RawWpmText}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="NetWpmTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="NetWpmLabelText" Text="Net WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="NetWpmValueText" Text="{Binding NetWpmText}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="AccuracyTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AccuracyLabelText" Text="Accuracy" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="AccuracyValueText" Text="{Binding AccuracyText}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            <controls:TypingInputSurface
                x:Name="InputSurface"
                Grid.Column="1"
                Background="Transparent"
                CharacterReceived="InputSurface_CharacterReceived"
                KeyDown="InputSurface_KeyDown"
                PointerPressed="InputSurface_PointerPressed"
                Tapped="InputSurface_Tapped">
                <Border
                    x:Name="InputBorder"
                    MaxWidth="1100"
                    Padding="32"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="InputSurface_PointerPressed"
                    Tapped="InputSurface_Tapped">
                    <StackPanel Spacing="12">
                        <ScrollViewer
                            x:Name="PracticeTextScrollViewer"
                            MinHeight="190"
                            MaxHeight="360"
                            Background="Transparent"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            PointerPressed="InputSurface_PointerPressed"
                            Tapped="InputSurface_Tapped">
                            <controls:PracticeTextPresenter
                                x:Name="PracticeTextPresenter"
                                FontFamilyName="{Binding PracticeFontFamily}"
                                TextContrast="{Binding PracticeTextContrast}"
                                CursorStyle="{Binding PracticeCursorStyle}"
                                Background="Transparent"
                                PointerPressed="InputSurface_PointerPressed"
                                Tapped="InputSurface_Tapped"
                                State="{Binding CurrentState}" />
                        </ScrollViewer>
                        <Border
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding ReadyStatusVisibility}">
                            <TextBlock Text="{Binding ReadyStatusText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <TextBlock
                            Text="{Binding TypingFeedback}"
                            Visibility="{Binding TypingFeedbackVisibility}"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        <Border
                            Padding="14"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Visibility="{Binding PauseOverlayVisibility}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding PauseTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PauseStatus}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" MinWidth="72">
                                    <TextBlock Text="{Binding NetWpmText}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Net WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" MinWidth="72">
                                    <TextBlock Text="{Binding AccuracyText}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Accuracy" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" MinWidth="64">
                                    <TextBlock Text="{Binding ElapsedText}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Time" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </controls:TypingInputSurface>
                <StackPanel
                    x:Name="RightStatsPanel"
                    Grid.Column="2"
                    Spacing="8"
                    Visibility="{Binding PracticeStatsVisibility}"
                    VerticalAlignment="Top">
                    <Border x:Name="ElapsedTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="ElapsedLabelText" Text="Time" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="ElapsedValueText" Text="{Binding ElapsedText}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ErrorsTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="ErrorsLabelText" Text="Errors" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="ErrorsValueText" Text="{Binding ErrorsText}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ProgressTile" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="ProgressLabelText" Text="Progress" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="ProgressValueText" Text="{Binding ProgressText}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock x:Name="CharactersText" Text="{Binding CharactersText}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            <controls:VisualKeyboardControl
                x:Name="VisualKeyboard"
                Layout="{Binding VisualKeyboardLayout}"
                HighlightedKeyId="{Binding HighlightedKeyId}"
                HighlightedShiftKeyId="{Binding HighlightedShiftKeyId}"
                ShowFingerColors="{Binding ShowFingerColors}"
                ShowFingerLabels="{Binding ShowFingerLabels}"
                Visibility="{Binding VisualKeyboardVisibility}" />
        </StackPanel>
        </Grid>

        <Grid
            x:Name="ReviewOverlay"
            Grid.RowSpan="2"
            Background="#CC0A0F16"
            Visibility="{Binding ReviewPopupVisibility}">
            <Border
                MaxWidth="1040"
                Margin="48"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Button
                        Width="34"
                        Height="34"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseReviewButton_Click">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                    </Button>
                <ScrollViewer
                    Grid.Row="1"
                    MaxHeight="676"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Session complete" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding CompletionStatus}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                                <Button Content="Restart" Click="RestartButton_Click" />
                                <Button Content="Next Lesson" Click="NextLessonButton_Click" />
                                <Button
                                    Content="Practice These Mistakes"
                                    Click="PracticeMistakesButton_Click"
                                    Visibility="{Binding PracticeMistakesVisibility}" />
                                <Button Content="Export Summary" Click="ExportSummaryButton_Click" />
                                <Button Content="View Dashboard" Click="ViewDashboardButton_Click" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Raw WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CompletionRawWpmText}" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Net WPM" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CompletionNetWpmText}" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Accuracy" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CompletionAccuracyText}" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Errors" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CompletionErrorsText}" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border
                            Padding="14"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding ReviewRecommendationTitle}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding ReviewRecommendationDetail}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Text="{Binding ReviewRetryStatus}"
                                    Visibility="{Binding ReviewRetryStatusVisibility}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="8">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Session Net WPM" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Hover over the line to inspect pace changes." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="16"
                                        VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SessionNetWpmHighText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding SessionNetWpmLowText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                                <controls:TrendLineChart
                                    Points="{Binding SessionNetWpmPoints}"
                                    ValueSuffix=" WPM"
                                    ChartTitle="Net WPM over time"
                                    XAxisLabel="Time"
                                    YAxisLabel="Net WPM"
                                    PointSelected="SessionNetWpmChart_PointSelected" />
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="10" Visibility="{Binding ReviewVisibility}">
                            <TextBlock Text="Review" FontSize="18" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding ReviewNotes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Margin="0,1,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Spacing="8">
                                <TextBlock Text="Most costly mistakes" FontWeight="SemiBold" />
                                <ListView ItemsSource="{Binding CostlyMistakeRows}" SelectionMode="None" MaxHeight="180">
                                    <ListView.Header>
                                        <Grid ColumnSpacing="10" Padding="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Target" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="Median ms" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="3" Text="Samples" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="4" Text="Impact" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="10" Padding="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Accuracy}" />
                                                <TextBlock Grid.Column="2" Text="{Binding MedianLatencyMs}" />
                                                <TextBlock Grid.Column="3" Text="{Binding Samples}" />
                                                <ProgressBar Grid.Column="4" Maximum="100" Value="{Binding ImpactPercent}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                            <ListView ItemsSource="{Binding ReviewRows}" SelectionMode="None" MaxHeight="280">
                                <ListView.Header>
                                    <Grid ColumnSpacing="10" Padding="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Type" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="Target" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="3" Text="Median ms" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="4" Text="Samples" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="5" Text="Weakness" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Kind}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Accuracy}" />
                                            <TextBlock Grid.Column="3" Text="{Binding MedianLatencyMs}" />
                                            <TextBlock Grid.Column="4" Text="{Binding Samples}" />
                                            <ProgressBar Grid.Column="5" Maximum="100" Value="{Binding WeaknessPercent}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
