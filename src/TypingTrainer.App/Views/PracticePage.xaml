<Page
    x:Class="TypingTrainer.App.Views.PracticePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="PracticePage_Loaded">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="TypingTrainer"
                    FontSize="28"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding LessonTitle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                    <Button Content="Practice" IsEnabled="False" />
                    <Button Content="Dashboard" Click="DashboardButton_Click" />
                    <Button Content="Settings" Click="SettingsButton_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="Lesson mode:" VerticalAlignment="Center" />
                    <ComboBox
                        x:Name="LessonModeComboBox"
                        Width="160"
                        SelectedIndex="0"
                        SelectionChanged="LessonModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Adaptive" />
                        <ComboBoxItem Content="Paragraph" />
                        <ComboBoxItem Content="Weak Keys" />
                        <ComboBoxItem Content="Weak Bigrams" />
                        <ComboBoxItem Content="Review" />
                        <ComboBoxItem Content="Fixed" />
                    </ComboBox>
                </StackPanel>
                <TextBlock
                    Text="{Binding LessonReason}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    Text="{Binding FocusKeysText}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="{Binding FocusBigramsText}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="{Binding LessonContentText}"
                    Visibility="{Binding LessonContentVisibility}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="24"
                VerticalAlignment="Center">
                <StackPanel MinWidth="72">
                    <TextBlock Text="{Binding RawWpmText}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="WPM" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel MinWidth="88">
                    <TextBlock Text="{Binding AccuracyText}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Accuracy" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel MinWidth="72">
                    <TextBlock Text="{Binding ElapsedText}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Time" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel MinWidth="72">
                    <TextBlock Text="{Binding ErrorsText}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Errors" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="1"
            Spacing="18"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center">
            <controls:TypingInputSurface
                x:Name="InputSurface"
                CharacterReceived="InputSurface_CharacterReceived"
                KeyDown="InputSurface_KeyDown"
                PointerPressed="InputSurface_PointerPressed"
                Tapped="InputSurface_Tapped">
                <Border
                    MaxWidth="1100"
                    Padding="32"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="InputSurface_PointerPressed"
                    Tapped="InputSurface_Tapped">
                    <StackPanel Spacing="18">
                        <controls:PracticeTextPresenter
                            State="{Binding CurrentState}" />
                        <TextBlock
                            Text="{Binding TypingFeedback}"
                            Visibility="{Binding TypingFeedbackVisibility}"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        <TextBlock
                            Text="{Binding CompletionStatus}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel
                            Spacing="14"
                            Visibility="{Binding CompletionPanelVisibility}">
                            <TextBlock Text="Session complete" FontSize="22" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionRawWpmText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Raw WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionNetWpmText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Net WPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="88">
                                    <TextBlock Text="{Binding CompletionAccuracyText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Accuracy" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel MinWidth="80">
                                    <TextBlock Text="{Binding CompletionErrorsText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Errors" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Restart" Click="RestartButton_Click" />
                                <Button Content="Next Lesson" Click="NextLessonButton_Click" />
                                <Button Content="View Dashboard" Click="ViewDashboardButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </controls:TypingInputSurface>
            <controls:VisualKeyboardControl
                Layout="{Binding VisualKeyboardLayout}"
                HighlightedKeyId="{Binding HighlightedKeyId}"
                HighlightedShiftKeyId="{Binding HighlightedShiftKeyId}"
                ShowFingerColors="{Binding ShowFingerColors}"
                ShowFingerLabels="{Binding ShowFingerLabels}"
                Visibility="{Binding VisualKeyboardVisibility}" />
        </StackPanel>
    </Grid>
</Page>
