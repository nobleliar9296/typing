<Window
    x:Class="TypingTrainer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TypingTrainer.App.Controls"
    Title="TypingTrainer">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:AppTopBar x:Name="TopBar" />
        <Frame
            x:Name="RootFrame"
            Grid.Row="1" />
    </Grid>
</Window>
