<UserControl
    x:Class="TypingTrainer.App.Controls.VisualKeyboardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    IsTabStop="False">
    <Border
        x:Name="KeyboardFrame"
        Padding="12"
        HorizontalAlignment="Stretch"
        Background="#303030"
        BorderBrush="#3A3A3A"
        BorderThickness="0"
        CornerRadius="10"
        IsHitTestVisible="False">
        <StackPanel
            x:Name="RowsPanel"
            Spacing="1" />
    </Border>
</UserControl>
