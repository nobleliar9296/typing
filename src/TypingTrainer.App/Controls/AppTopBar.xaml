<UserControl
    x:Class="TypingTrainer.App.Controls.AppTopBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinHeight="42">
    <Border
        Padding="18,5"
        Background="#191919"
        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
        BorderThickness="0,0,0,1">
        <Grid ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="TypingTrainer"
                FontSize="15"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4"
                VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2" />
                    </Grid.RowDefinitions>
                    <Button
                        x:Name="PracticeButton"
                        Content="Practice"
                        Click="PracticeButton_Click"
                        Padding="14,4" />
                    <Border
                        x:Name="PracticeUnderline"
                        Grid.Row="1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="1" />
                </Grid>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2" />
                    </Grid.RowDefinitions>
                    <Button
                        x:Name="DashboardButton"
                        Content="Dashboard"
                        Click="DashboardButton_Click"
                        Padding="14,4" />
                    <Border
                        x:Name="DashboardUnderline"
                        Grid.Row="1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="1" />
                </Grid>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2" />
                    </Grid.RowDefinitions>
                    <Button
                        x:Name="SettingsButton"
                        Content="Settings"
                        Click="SettingsButton_Click"
                        Padding="14,4" />
                    <Border
                        x:Name="SettingsUnderline"
                        Grid.Row="1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="1" />
                </Grid>
            </StackPanel>

            <TextBlock
                Grid.Column="2"
                Text="Local only"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Border>
</UserControl>
